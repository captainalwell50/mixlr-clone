APP_NAME="Live Mix Audio"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Requires PHP 8.4+ (Composer platform check).

# First admin user from DatabaseSeeder (password: password via factory)
ADMIN_EMAIL=admin@example.com

# Self-serve creator signup. Set true on SaaS deploy; keep false for single-tenant church installs.
REGISTRATION_ENABLED=false

# Paystack billing (NGN default). Create matching Plans in Paystack Dashboard.
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_CURRENCY=NGN
PAYSTACK_PLAN_STARTER=
PAYSTACK_PLAN_PRO=
# Amounts in kobo (or lowest currency unit): 500000 = ₦5,000
PAYSTACK_PLAN_STARTER_AMOUNT=500000
PAYSTACK_PLAN_PRO_AMOUNT=1500000

# Laravel recording retention (scheduled recordings:prune). Align with MediaMTX recordDeleteAfter.
RECORDING_RETENTION_DAYS=365

# Subdirectory under storage/app/ — docker-compose binds this to MediaMTX /recordings
MEDIAMTX_RECORDINGS_PATH=mediamtx-recordings

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Object storage for recordings + platform library (Cloudflare R2 recommended).
# Leave OBJECT_STORAGE_ENABLED=false to keep files on the VM disk only.
OBJECT_STORAGE_ENABLED=false
OBJECT_STORAGE_DISK=s3
OBJECT_STORAGE_PREFIX=live-mix
OBJECT_STORAGE_DELETE_LOCAL_AFTER_SYNC=false
OBJECT_STORAGE_SIGNED_URL_MINUTES=120
OBJECT_STORAGE_DEFAULT_ORG_QUOTA_BYTES=2147483648

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_ENDPOINT=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=true

# Google Drive BYO library (OAuth). Create OAuth client in Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI="${APP_URL}/integrations/google-drive/callback"

VITE_APP_NAME="${APP_NAME}"

# MediaMTX (see docker-compose.yml) — public URLs used by the browser for WHIP + HLS
MEDIAMTX_WEBRTC_PUBLIC_BASE=http://127.0.0.1:8889
MEDIAMTX_HLS_PUBLIC_BASE=http://127.0.0.1:8888

# Optional CDN / Azure Front Door in front of HLS (Listen uses this when set)
# MEDIAMTX_HLS_CDN_BASE=https://cdn.example.org/hls

# OBS / RTMP publish base (path live/<uuid> is appended)
MEDIAMTX_RTMP_PUBLIC_BASE=rtmp://127.0.0.1:1935

# Laravel webhook called from MediaMTX hooks (image includes curl; URL must be reachable from Docker)
# Local: MEDIAMTX_WEBHOOK_URL=http://host.docker.internal:8000/api/webhooks/mediamtx
# Azure VM: MEDIAMTX_WEBHOOK_URL=https://stream.example.org/api/webhooks/mediamtx
MEDIAMTX_WEBHOOK_URL=
MEDIAMTX_WEBHOOK_SECRET=

# MediaMTX HTTP auth → Laravel (publish only for known streams). Used by docker-compose / mediamtx.yml.
MEDIAMTX_AUTH_URL=http://host.docker.internal:8000/api/mediamtx/auth

# Optional: if set, WHIP publishers must send this as password or ?publish_secret=
MEDIAMTX_PUBLISH_SECRET=

# Laravel scheduler (production): cron `* * * * * php /path/to/artisan schedule:run`
