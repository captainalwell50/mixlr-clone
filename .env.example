APP_NAME="Church Live"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Requires PHP 8.4+ (Composer platform check).

# First admin user from DatabaseSeeder (password: password via factory)
ADMIN_EMAIL=admin@example.com

# Disable /register UI + return 404 for registration when false (church default).
REGISTRATION_ENABLED=false

# Laravel recording retention (scheduled recordings:prune). Align with MediaMTX recordDeleteAfter.
RECORDING_RETENTION_DAYS=365

# Subdirectory under storage/app/ — docker-compose binds this to MediaMTX /recordings
MEDIAMTX_RECORDINGS_PATH=mediamtx-recordings

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# MediaMTX (see docker-compose.yml) — public URLs used by the browser for WHIP + HLS
MEDIAMTX_WEBRTC_PUBLIC_BASE=http://127.0.0.1:8889
MEDIAMTX_HLS_PUBLIC_BASE=http://127.0.0.1:8888

# Optional CDN / Azure Front Door in front of HLS (Listen uses this when set)
# MEDIAMTX_HLS_CDN_BASE=https://cdn.example.org/hls

# OBS / RTMP publish base (path live/<uuid> is appended)
MEDIAMTX_RTMP_PUBLIC_BASE=rtmp://127.0.0.1:1935

# Laravel webhook called from MediaMTX hooks (image includes curl; URL must be reachable from Docker)
# Local: MEDIAMTX_WEBHOOK_URL=http://host.docker.internal:8000/api/webhooks/mediamtx
# Azure VM: MEDIAMTX_WEBHOOK_URL=https://stream.example.org/api/webhooks/mediamtx
MEDIAMTX_WEBHOOK_URL=
MEDIAMTX_WEBHOOK_SECRET=

# MediaMTX HTTP auth → Laravel (publish only for known streams). Used by docker-compose / mediamtx.yml.
MEDIAMTX_AUTH_URL=http://host.docker.internal:8000/api/mediamtx/auth

# Optional: if set, WHIP publishers must send this as password or ?publish_secret=
MEDIAMTX_PUBLISH_SECRET=

# Laravel scheduler (production): cron `* * * * * php /path/to/artisan schedule:run`
